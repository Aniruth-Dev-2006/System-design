generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InterviewLink {
  id          String   @id @default(uuid())
  title       String
  problemDesc String?
  level       String   @default("medium")
  durationMin Int      @default(30)
  createdAt   DateTime @default(now())
  
  sessions    InterviewSession[]
}

model InterviewSession {
  id              String   @id @default(uuid())
  interviewLinkId String
  candidateName   String?
  status          String   @default("pending") // pending, completed
  score           Int?
  reportJson      String?  // JSON string
  canvasJson      String?  // JSON string
  transcriptJson  String?  // JSON string
  startedAt       DateTime?
  completedAt     DateTime?
  
  link            InterviewLink @relation(fields: [interviewLinkId], references: [id])
}
